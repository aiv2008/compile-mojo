{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mojo: run main",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/mojo",
      "args": ["run", "main.mojo"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "mojo: build main",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/mojo",
      "args": ["build", "main.mojo", "-o", "main"],
      "problemMatcher": []
    }
  ]
}
